    <meta property="og:description" content="Creative Divine Concepts offers professional web design, development, and digital solutions. Create stunning websites, e-commerce stores, and custom web applications." />
    <meta property="og:image" content="https://creativedivineconcepts.com/logo.jpeg" />
    <meta property="og:site_name" content="Creative Divine Concepts" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content="https://creativedivineconcepts.com/" />
