    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Inter:wght@400;500;700&family=League+Spartan:wght@400;700&display=swap" rel="stylesheet">
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta name="theme-color" content="#0f172a" />

    <!-- Primary Meta Tags -->
    <title>Creative Divine Concepts | Premium Web Design & Development Services</title>
    <meta name="title" content="Creative Divine Concepts | Premium Web Design & Development Services" />
    <meta name="description" content="Creative Divine Concepts offers professional web design, development, and digital solutions. Create stunning websites, e-commerce stores, and custom web applications with our expert team." />
    <meta name="author" content="Creative Divine Concepts" />
    <meta name="robots" content="index, follow" />
